{
  "name": "twinnet-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "ethers": "6.13.1"
  },
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @twinnet/api",
    "dev:web": "npm run dev -w @twinnet/web",
    "build": "npm run build --workspaces --if-present",
    "contracts:compile": "npm run compile -w @twinnet/contracts",
    "contracts:deploy": "npm run deploy -w @twinnet/contracts",
    "check:0g": "npm run check:0g -w @twinnet/api"
  }
}
